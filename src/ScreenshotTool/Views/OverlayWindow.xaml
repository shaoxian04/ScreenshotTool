<Window x:Class="ScreenshotTool.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ScreenshotTool.Views"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="Cross">
    <Canvas x:Name="MainCanvas" ClipToBounds="True">
        <!-- Screenshot background -->
        <Image x:Name="ScreenshotImage" Stretch="Fill" IsHitTestVisible="False"/>

        <!-- Dark overlay (drawn in code-behind) -->
        <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False"/>

        <!-- Selection border with resize handles -->
        <Border x:Name="SelectionBorder" BorderBrush="#0078D4" BorderThickness="2"
                Visibility="Collapsed" IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" Opacity="0.5" ShadowDepth="0" Color="#0078D4"/>
            </Border.Effect>
        </Border>

        <!-- Resize handles -->
        <Canvas x:Name="HandlesCanvas" Visibility="Collapsed"/>

        <!-- Annotation drawing surface -->
        <Canvas x:Name="AnnotationCanvas" IsHitTestVisible="False"/>

        <!-- Dimension indicator -->
        <Border x:Name="DimensionLabel" Background="#CC000000" CornerRadius="3"
                Padding="6,2" Visibility="Collapsed" IsHitTestVisible="False">
            <TextBlock x:Name="DimensionText" Foreground="White" FontSize="12" FontFamily="Segoe UI"/>
        </Border>

        <!-- Toolbar -->
        <views:ToolbarControl x:Name="Toolbar" Visibility="Collapsed"/>

        <!-- Text input overlay -->
        <TextBox x:Name="TextInputBox" Visibility="Collapsed"
                 Background="#80000000" Foreground="White" BorderBrush="#0078D4"
                 BorderThickness="1" FontSize="16" FontFamily="Segoe UI"
                 AcceptsReturn="True" MinWidth="100" Padding="4,2"
                 LostFocus="TextInput_LostFocus" KeyDown="TextInput_KeyDown"/>
    </Canvas>
</Window>
