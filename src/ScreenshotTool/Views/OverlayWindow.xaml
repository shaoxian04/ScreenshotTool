<Window x:Class="ScreenshotTool.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ScreenshotTool.Views"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="Cross">
    <Canvas x:Name="MainCanvas" ClipToBounds="True">
        <!-- Screenshot background -->
        <Image x:Name="ScreenshotImage" Stretch="Fill" IsHitTestVisible="False"/>

        <!-- Dark overlay (drawn in code-behind) -->
        <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False"/>

        <!-- Selection border with resize handles -->
        <Border x:Name="SelectionBorder" BorderBrush="#0078D4" BorderThickness="2"
                Visibility="Collapsed" IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" Opacity="0.5" ShadowDepth="0" Color="#0078D4"/>
            </Border.Effect>
        </Border>

        <!-- Resize handles -->
        <Canvas x:Name="HandlesCanvas" Visibility="Collapsed"/>

        <!-- Annotation drawing surface -->
        <Canvas x:Name="AnnotationCanvas" IsHitTestVisible="False"/>

        <!-- Dimension indicator -->
        <Border x:Name="DimensionLabel" Background="#CC000000" CornerRadius="3"
                Padding="6,2" Visibility="Collapsed" IsHitTestVisible="False">
            <TextBlock x:Name="DimensionText" Foreground="White" FontSize="12" FontFamily="Segoe UI"/>
        </Border>

        <!-- Toolbar -->
        <views:ToolbarControl x:Name="Toolbar" Visibility="Collapsed"/>

        <!-- Text input overlay -->
        <TextBox x:Name="TextInputBox" Visibility="Collapsed"
                 Background="#80000000" Foreground="White" BorderBrush="#0078D4"
                 BorderThickness="1" FontSize="16" FontFamily="Segoe UI"
                 AcceptsReturn="True" MinWidth="100" Padding="4,2"
                 LostFocus="TextInput_LostFocus" KeyDown="TextInput_KeyDown"/>

        <!-- OCR Result Panel -->
        <Border x:Name="OcrResultPanel" Visibility="Collapsed"
                Background="#F0222222" CornerRadius="10" Padding="16"
                MouseLeftButtonDown="OcrPanel_MouseDown"
                MouseLeftButtonUp="OcrPanel_MouseUp"
                MouseMove="OcrPanel_MouseMove">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" Opacity="0.5" ShadowDepth="4"/>
            </Border.Effect>
            <StackPanel Width="340">
                <!-- Header -->
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="OCR Result" Foreground="White" FontSize="14"
                               FontWeight="SemiBold" FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                    <Button x:Name="OcrCloseBtn" Content="✕" DockPanel.Dock="Right"
                            Width="24" Height="24" Padding="0"
                            FontSize="12" Foreground="#AAA" Background="Transparent"
                            BorderThickness="0" Cursor="Hand"
                            Click="OcrClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#44FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </DockPanel>

                <!-- Scanned text (editable so user can fix OCR errors) -->
                <Border Background="#1A1A1A" CornerRadius="6" Padding="1" Margin="0,0,0,12">
                    <TextBox x:Name="OcrResultText"
                             Background="Transparent" Foreground="White"
                             BorderThickness="0" FontSize="13" FontFamily="Segoe UI"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MaxHeight="200" VerticalScrollBarVisibility="Auto"
                             Padding="8,6" CaretBrush="White" SelectionBrush="#440078D4"/>
                </Border>

                <!-- Copy button -->
                <Button Content="Copy to Clipboard" Height="34" FontSize="13"
                        FontFamily="Segoe UI" FontWeight="SemiBold"
                        Foreground="White" Cursor="Hand"
                        Click="OcrCopy_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#0078D4" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#0063B1"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#004E8C"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Canvas>
</Window>
