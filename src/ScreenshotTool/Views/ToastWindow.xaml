<Window x:Class="ScreenshotTool.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">
    <Border Background="#E0333333" CornerRadius="8" Padding="16,10" Margin="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" Opacity="0.3" ShadowDepth="2"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#x2713;" Foreground="#4CAF50" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="MessageText" Text="Screenshot copied to clipboard"
                       Foreground="White" FontSize="14" FontFamily="Segoe UI" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
